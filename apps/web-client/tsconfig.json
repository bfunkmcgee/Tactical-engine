{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "engine-core": [
        "../../packages/engine-core/index.ts"
      ],
      "rules-sdk": [
        "../../packages/rules-sdk/index.ts"
      ],
      "rules-sdk/hooks": [
        "../../packages/rules-sdk/hooks.ts"
      ],
      "rules-sdk/scenario-runtime": [
        "../../packages/rules-sdk/scenario-runtime.ts"
      ],
      "engine-spatial": [
        "../../packages/engine-spatial/index.ts"
      ],
      "engine-entities": [
        "../../packages/engine-entities/index.ts"
      ],
      "game-scenarios/runtime-registry": [
        "../../games/scenario-runtime-registry.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}
