{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noEmit": false,
    "outDir": ".tmp-test-dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "apps/web-client/src/ui/input/**/*.ts"
  ],
  "exclude": [
    "node_modules/**",
    ".tmp-test-dist/**"
  ]
}
