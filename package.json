{
  "name": "tactical-engine-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "games/*",
    "tools"
  ],
  "scripts": {
    "build": "pnpm -r --filter ./packages/** run build && pnpm --filter ./apps/web-client run build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:contracts": "vitest run tests/contract",
    "validate:content": "tsx tools/validate-content.ts",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "zod": "^3.24.3"
  }
}
